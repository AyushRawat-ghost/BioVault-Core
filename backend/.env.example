# Go Backend Service Port
PORT=5000

# Blockchain RPC Node
RPC_URL=http://127.0.0.1:8545

# AWS RDS PostgreSQL Database
# Format: postgres://<user>:<password>@<rds-endpoint>:<port>/<database-name>?sslmode=require
DATABASE_URL=postgres://postgres:password@your-rds-endpoint.amazonaws.com:5432/biovault?sslmode=require

# AWS S3 Bucket Storage Configuration (For medical PDF vaults & patient profile pictures)
AWS_REGION=us-east-1
AWS_S3_BUCKET=biovault-core-records
AWS_ACCESS_KEY_ID=your-iam-access-key-id
AWS_SECRET_ACCESS_KEY=your-iam-secret-access-key

# AWS Bedrock AI Configuration (For clinical summaries & allergen warnings)
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# ML Microservice URL (FastAPI vitals prediction model)
ML_SERVICE_URL=http://localhost:8000

# Deployed Smart Contract Addresses (Local MetaMask testnet / Hardhat node addresses)
PATIENT_REGISTRY_ADDR=0x...
DOCTOR_REGISTRY_ADDR=0x...
MEDICAL_RECORD_ADDR=0x...
ACCESS_REQUEST_ADDR=0x...

# Backend Transaction Signer Key (Used for anchoring PDF hashes to smart contracts)
DEPLOYER_PRIVATE_KEY=your-ethereum-private-key-hex
